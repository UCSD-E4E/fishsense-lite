# Copy to deploy/.env. The compose.local.yml stack reads this automatically.
#
# REQUIRED — absolute path of *this repository* on your host. The dev service
# bind-mounts the repo at the same path inside the container as outside, so
# any tool that keys state by absolute path (notably Claude Code's per-project
# memory) sees a consistent path whether running on the host or inside the
# container. Set to the output of `realpath ..` from this directory.
#HOST_REPO_PATH=/home/you/code/fishsense-lite-mono

# REQUIRED — host docker group GID. The dev service bind-mounts
# /var/run/docker.sock and adds `vscode` to a supplementary group with this
# numeric GID so the user can run docker commands from inside the container
# (e.g. to recreate sibling services). Get it with:
#     getent group docker | cut -d: -f3
#DOCKER_GID=999

# REQUIRED — point at the prod backup on your host. Custom-format pg_dump.
# Leave commented to boot with empty databases (still useful for shape work).
#FISHSENSE_DUMP_PATH=/home/you/2026-04-26_fishsense_backup

# Local-only secrets. Defaults are fine; change if anything ever ports.
POSTGRES_PASSWORD=fishsense_local
TEMPORAL_DB_PWD=temporal_local

# Database name to restore the dump into.
FISHSENSE_DB_NAME=fishsense

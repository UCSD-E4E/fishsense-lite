# fishsense-data-processing-workflow-worker secrets — TEMPLATE.
#
# Copy to `.secrets.toml` (gitignored — `.gitignore` matches that exact
# filename, not this `.example`) and fill in the real values. On NRP
# these are delivered as a Kubernetes Secret mounted alongside the
# `settings.toml` ConfigMap; the keys are the same. Dynaconf merges
# this on top of `settings.toml` at worker startup; required-key set is
# defined by the validators in
# services/fishsense-data-processing-workflow-worker/src/.../config.py.
#
# Two credential surfaces, both HTTP Basic, both going through the
# orchestrator's Traefik + authentik (the data-worker is off the
# orchestrator's docker network):
#
# * fishsense_api — service-account credentials the SDK presents to
#   fishsense-api (authentik basic-auth-passthrough on the API route).
# * file_exchange — service-account credentials the worker presents to
#   the static_file_server `/api/v1/exchange/*` route (also authentik
#   basic-auth-passthrough; replaced the old single-IP allowlist that
#   couldn't survive the move to NRP). Both username and password must
#   be set or no auth header is sent.
#
# By design there is no [e4e_nas] block here — the data-worker never
# touches the NAS. The api-worker stages bytes onto the file-exchange
# before dispatching child workflows.

[fishsense_api]
username = "<service-account>"
password = "<service-account-password>"

[file_exchange]
username = "<exchange-service-account>"
password = "<exchange-service-account-password>"

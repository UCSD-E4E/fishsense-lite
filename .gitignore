.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Notebook artifacts
.ipynb_checkpoints/

# Local secrets (never commit)
.secrets/
.secrets.toml
*.env
!example.env
!*.env.example

# deploy/.env is the user-specific devcontainer env (paths, local passwords).
# deploy/.env.local.example is the committed template.
deploy/.env

# Postgres dumps must never land in the repo (large). The committed *.sql
# files under deploy/pg_volumes/scripts/ are schema migrations, not dumps —
# only dump-like extensions are blocked here.
*.dump
*.pgdump
*_backup
*_backup.sql

# Stage13 refactor validation + dry-run outputs (contain prod data samples)
services/fishsense-data-processing-workflow-worker/scripts/validate_stage13_refactor_*.json
services/fishsense-data-processing-workflow-worker/scripts/dry_run_stage13_*.json

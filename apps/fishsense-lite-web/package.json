  },
  "devDependencies": {
    "@types/node": "24.0.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.4",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "postcss": "8.5.21",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vitest": "4.1.10"
  },
  "overrides": {
